# TMDB API (required)
TMDB_API_KEY=your_tmdb_api_key_here

# Backend (optional, defaults shown)
SPRING_PROFILES_ACTIVE=h2
SERVER_PORT=8080

# PostgreSQL (only when SPRING_PROFILES_ACTIVE=postgres)
PGHOST=localhost
PGPORT=5432
PGDATABASE=movielab
PGUSER=postgres
PGPASSWORD=postgres

# Frontend
VITE_API_URL=http://localhost:8080/graphql
